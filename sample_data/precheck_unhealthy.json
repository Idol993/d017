version: "1.0"
description: "物流园区前置校验样例数据 - 异常状态，部分指标未达标"
statistical_period:
  start: "2026-06-13T00:00:00"
  end: "2026-06-19T23:59:59"
  days: 7

target_parks:
  - "PK-CENTER-01"
  - "PK-SOUTH-01"
  - "PK-EAST-03"
  - "PK-WEST-02"

metrics:
